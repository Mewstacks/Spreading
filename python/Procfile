# Processos do app (honcho/Fly). Uma máquina só — compartilham o volume de sessões.
# gunicorn serve o Django; os workers rodam os loops de automação full-time.
web: gunicorn core.wsgi:application --chdir django --bind 0.0.0.0:8080 --workers 2 --timeout 120
scrape: python django/manage.py automacao --modo scrape --scrape-horas 3
scrapeflash: python django/manage.py automacao --modo scrape_rapido --tick 5
envio: python django/manage.py automacao --modo envio --tick 5
canais: python django/manage.py monitorar_canais --tick 60
